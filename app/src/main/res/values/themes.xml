<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MarcadorTruco" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/truco_primary</item>
        <item name="colorPrimaryDark">@color/truco_primary_dark</item>
        <item name="colorOnPrimary">@color/truco_on_primary</item>
        <item name="colorPrimaryContainer">@color/truco_primary_container</item>
        <item name="colorSecondary">@color/truco_secondary</item>
        <item name="android:colorAccent">@color/truco_primary</item>
        <item name="android:windowBackground">@color/truco_background</item>
        <item name="android:navigationBarColor">@color/truco_background</item>
        <item name="android:statusBarColor">@color/truco_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="materialButtonStyle">@style/Widget.MarcadorTruco.Button</item>
        <item name="materialCardViewStyle">@style/Widget.MarcadorTruco.Card</item>
    </style>

    <style name="Theme.MarcadorTruco" parent="Base.Theme.MarcadorTruco" />

    <style name="Widget.MarcadorTruco.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/truco_primary</item>
        <item name="android:textColor">@color/truco_on_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.MarcadorTruco.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/truco_surface</item>
        <item name="cardCornerRadius">8dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.MarcadorTruco.Button.Score" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/truco_primary_container</item>
        <item name="android:textColor">@color/truco_primary_dark</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingLeft">0dp</item>
        <item name="android:paddingRight">0dp</item>
        <item name="android:singleLine">true</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.MarcadorTruco.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/truco_outline</item>
        <item name="android:textColor">@color/truco_text</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.MarcadorTruco.Button.Danger" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">@color/truco_danger_container</item>
        <item name="android:textColor">@color/truco_danger</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
